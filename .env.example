SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True

# ───── Database ─────────────────────────────────────────────────────────────
# Local development: SQLite (mặc định, không cần cấu hình thêm)
DB_ENGINE=sqlite

# Production (Windows VPS / Linux): đặt DB_ENGINE=postgresql và điền đầy đủ
# DB_ENGINE=postgresql
# DB_NAME=aitrading
# DB_USER=postgres
# DB_PASSWORD=your_postgres_password
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_SSLMODE=                        # để trống nếu local; require nếu dùng cloud (Neon, Supabase...)

# ───── Email ─────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password

# ───── Blockchain / Nạp tiền ────────────────────────────────────────────────
ADMIN_WALLET_ADDRESS=0xYourMetaMaskWalletAddress
USDT_CONTRACT_BSC=0x55d398326f99059fF775485246999027B3197955
BSCSCAN_API_KEY=your_bscscan_api_key
USDT_TO_COINS_RATE=1
WALLET_SCAN_INTERVAL_SECONDS=60
DJANGO_RUN_SCHEDULER=0              # set 1 trong production

# ───── MetaTrader5 ───────────────────────────────────────────────────────────
MT5_ACCOUNT=
MT5_PASSWORD=
MT5_SERVER=

# ───── Gemini AI ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ───── Redis (bắt buộc) ──────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ───── Giá gói đăng ký (đơn vị: xu) ─────────────────────────────────────────
AI_PLAN_WEEK_COST=20
AI_PLAN_MONTH_COST=50
AI_PLAN_YEAR_COST=400

TV_PLAN_WEEK_COST=10
TV_PLAN_MONTH_COST=30
TV_PLAN_YEAR_COST=200
